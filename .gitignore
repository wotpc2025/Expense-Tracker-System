# Ignore rules for local/dev artifacts, secrets, generated outputs, and DB dumps.
# See: https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (do not commit local secrets)
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mysql
*.sql
drizzle/