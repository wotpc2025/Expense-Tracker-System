@startuml ActivityUC15AdminAuditLog
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_15 ตรวจสอบบันทึกเหตุการณ์ระบบ

|ผู้ดูแลระบบ|
start
:เลือกเมนู Admin - Audit Logs;

|ระบบ|
:ดึงข้อมูลบันทึกเหตุการณ์;
:เรียงลำดับจากล่าสุด;
:แสดงรายการเหตุการณ์;

|ผู้ดูแลระบบ|
:ตรวจสอบผู้กระทำและเวลาที่เกิดเหตุการณ์;
stop
@enduml