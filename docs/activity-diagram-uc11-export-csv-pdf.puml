@startuml ActivityUC11Export
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_11 ส่งออกข้อมูลรายงานแบบ CSV/PDF

|ผู้ใช้งาน|
start
:เปิดหน้ารายงาน;
:เลือกประเภทไฟล์ (CSV หรือ PDF);
:กดปุ่มส่งออก;

|ระบบ|
:สร้างไฟล์ตามรูปแบบที่เลือก;
:จัดเตรียมข้อมูลดาวน์โหลด;
:ส่งไฟล์ให้ผู้ใช้งาน;

|ผู้ใช้งาน|
:ดาวน์โหลดไฟล์รายงาน;
stop
@enduml
