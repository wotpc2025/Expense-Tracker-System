@startuml ExpenseManagementSystemDiagram
top to bottom direction
scale max 1700 width

skinparam defaultFontName Tahoma
skinparam defaultFontSize 15
skinparam titleFontSize 24
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor white
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam ArrowColor #2f2f2f
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 90
skinparam packageBorderColor #8a8a8a
skinparam packageBackgroundColor #f7f7f7
skinparam RectangleBorderColor #6f6f6f
skinparam RectangleBackgroundColor #fcfcfc

title System Architecture Diagram: Expense Management System

actor "User" as USER
actor "Admin" as ADMIN
USER -[hidden]- ADMIN

package "Client Layer" #f2f6ff {
	node "Web Browser\n(Chrome / Edge)" as BROWSER
}

package "Edge Routing & Security" #f4f4f4 {
	cloud "Cloudflare\nZero Trust" as CF
	node "Nginx Proxy Manager\nReverse Proxy (:3068)" as NGINX
}

package "Primary Application Region" #f9fff2 {
	package "Application Services (Next.js 16)" #eef9ee {
		component "Web UI\nDashboard / Budgets / Expenses / Reports" as WEBUI
		component "Server Actions\ndbActions" as ACTIONS
		component "API Routes\n/ai/scan-receipt\n/health/db" as API
		rectangle "Business Logic\nValidation + Normalization\nAlert & Audit Rules" as LOGIC

		WEBUI -[hidden]down- ACTIONS
		ACTIONS -[hidden]- API
		ACTIONS -[hidden]down- LOGIC
		API -[hidden]down- LOGIC
	}

	package "Data Layer" #eef6ff {
		database "MySQL (MariaDB)" as DB
	}

	LOGIC -[hidden]down- DB
}

package "External Managed Services" #f7f1ff {
	cloud "Clerk\nIdentity + Session" as CLERK
	cloud "OpenRouter AI\nReceipt Scan Service" as OAI
	CLERK -[hidden]- OAI
}

USER --> BROWSER : Use system
ADMIN --> BROWSER : Admin access

BROWSER --> CF : HTTPS
CF --> NGINX : Tunnel / Gateway
NGINX --> WEBUI : Reverse Proxy

WEBUI --> ACTIONS : Budget/Expense actions
WEBUI --> API : API calls
ACTIONS --> LOGIC : Validate rules
API --> LOGIC : Parse + validate

LOGIC --> DB : Drizzle ORM + mysql2
ACTIONS --> CLERK : verify user/session
API --> OAI : Receipt image scan

DB --> WEBUI : Dashboard/Report data
DB --> LOGIC : Alert + Audit source

WEBUI -[hidden]down- CLERK
DB -[hidden]down- OAI

@enduml
