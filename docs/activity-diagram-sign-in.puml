@startuml ActivitySignIn
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  BarColor #666666
  DiamondBorderColor #666666
  DiamondBackgroundColor #f8f8f8
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title แผนภาพกิจกรรมการเข้าสู่ระบบ

|ผู้ใช้งาน (ผู้ใช้, แอดมิน)|
start
:กรอกอีเมลและรหัสผ่าน;

|ระบบ|
:ตรวจสอบความถูกต้องของข้อมูล;

if (ข้อมูลถูกต้อง?) then (Yes)
  :ตรวจสอบสิทธิ์ผู้ใช้งาน;
  :แสดงหน้าหลักพร้อมเมนูตามสิทธิ์;
  stop
else (No)
  :แสดงข้อความแจ้งเตือน;
  |ผู้ใช้งาน (ผู้ใช้, แอดมิน)|
  :กรอกข้อมูลใหม่อีกครั้ง;
  |ระบบ|
  :กลับไปหน้าเข้าสู่ระบบ;
  stop
endif
@enduml
