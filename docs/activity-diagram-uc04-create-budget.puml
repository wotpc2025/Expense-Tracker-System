@startuml ActivityUC04CreateBudget
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_04 สร้างข้อมูลงบประมาณ

|ผู้ใช้งาน|
start
:เลือกเมนูงบประมาณ;
:กดปุ่มสร้างงบประมาณ;
:กรอกชื่อ วงเงิน หมวดหมู่;
:กดบันทึก;

|ระบบ|
:ตรวจสอบข้อมูล;
if (ข้อมูลถูกต้อง?) then (Yes)
  :บันทึกงบประมาณใหม่;
  :แสดงผลสร้างสำเร็จ;
  stop
else (No)
  :แจ้งข้อผิดพลาด;
  stop
endif
@enduml
