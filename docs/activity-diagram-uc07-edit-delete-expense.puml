@startuml ActivityUC07EditDeleteExpense
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_07 แก้ไขและลบรายการค่าใช้จ่าย

|ผู้ใช้งาน|
start
:เลือกรายการค่าใช้จ่าย;
if (เลือกแก้ไข?) then (Yes)
  :แก้ไขข้อมูลรายการ;
  :กดยืนยัน;
  |ระบบ|
  :อัปเดตรายการค่าใช้จ่าย;
  :แสดงผลแก้ไขสำเร็จ;
  stop
else (No)
  :ยืนยันการลบรายการ;
  |ระบบ|
  :ลบรายการค่าใช้จ่าย;
  :อัปเดตยอดสรุป;
  stop
endif
@enduml
