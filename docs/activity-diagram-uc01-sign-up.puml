@startuml ActivityUC01SignUp
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_01 สมัครสมาชิก

|ผู้ใช้งาน|
start
:เปิดหน้า Landing Page;
:กดปุ่ม Get Started;
:เลือกเมนูสมัครสมาชิก;
:กรอกข้อมูลสมัครสมาชิก;

|ระบบ|
:ตรวจสอบความถูกต้องของข้อมูล;
if (ข้อมูลถูกต้อง?) then (Yes)
  :สร้างบัญชีผู้ใช้ผ่าน Clerk;
  :แสดงผลสมัครสมาชิกสำเร็จ;
  stop
else (No)
  :แจ้งข้อผิดพลาด;
  stop
endif
@enduml
