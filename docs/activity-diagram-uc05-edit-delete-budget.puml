@startuml ActivityUC05EditDeleteBudget
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_05 แก้ไขและลบงบประมาณ

|ผู้ใช้งาน|
start
:เลือกงบประมาณที่ต้องการจัดการ;
if (เลือกแก้ไข?) then (Yes)
  :แก้ไขข้อมูลงบประมาณ;
  :ยืนยันการบันทึก;
  |ระบบ|
  :อัปเดตข้อมูลงบประมาณ;
  :แสดงผลแก้ไขสำเร็จ;
  stop
else (No)
  :ยืนยันการลบงบประมาณ;
  |ระบบ|
  :ลบงบประมาณและข้อมูลที่เกี่ยวข้อง;
  :แสดงผลลบสำเร็จ;
  stop
endif
@enduml
