@startuml ActivityUC06AddExpense
skinparam defaultFontName Tahoma
skinparam dpi 140
skinparam shadowing false
skinparam backgroundColor #f0f0f0
skinparam activity {
  BackgroundColor #f8f8f8
  BorderColor #666666
  FontColor #111111
  StartColor black
  EndColor black
  RoundCorner 8
}
skinparam PartitionBorderColor #777777
skinparam PartitionBackgroundColor #efefef
skinparam ArrowColor #555555

title UC_06 เพิ่มรายการค่าใช้จ่าย

|ผู้ใช้งาน|
start
:เลือกเมนูค่าใช้จ่าย;
:กดปุ่มเพิ่มค่าใช้จ่าย;
:กรอกชื่อรายการ จำนวนเงิน และหมวดหมู่;
:กดบันทึก;

|ระบบ|
:ตรวจสอบข้อมูล;
if (ข้อมูลถูกต้อง?) then (Yes)
  :บันทึกรายการค่าใช้จ่าย;
  :อัปเดตยอดคงเหลือของงบประมาณ;
  stop
else (No)
  :แจ้งข้อผิดพลาด;
  stop
endif
@enduml
